# Eyestream Configuration
# Copy this file to .env and adjust values

# === Database ===
DB_NAME=eyestream
DB_USER=eyestream
DB_PASSWORD=eyestream

# === Timezone ===
TZ=Europe/Berlin

# === Branding ===
BRAND_NAME=Eyestream
PRODUCT_NAME=Eyestream
# Logo URL (leave empty to hide logo)
LOGO_URL=

# === URLs ===
# Public CDN URL (where HLS streams are served from)
PUBLIC_BASE=https://video.example.com

# === Footer ===
# Format: Label1|URL1,Label2|URL2
FOOTER_LINKS=Impressum|https://example.com/impressum,Datenschutz|https://example.com/privacy
COPYRIGHT_TEXT=© 2026 Your Company

# === Example Page ===
# Leave empty to hide the "Example" link in the header
EXAMPLE_PAGE_URL=

# === NPM Log Analysis (optional) ===
NPM_SITE_ID=
NPM_LOG_HOST_PATH=../npm/data/logs

# === Referer Analysis ===
# Comma-separated domains/patterns to ignore in referer analysis
REFERER_IGNORE_SEEDS=localhost
